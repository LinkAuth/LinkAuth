# ===========================================================================
# LinkAuth — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
#
# Convention (per provider):
#   OAUTH_{PROVIDER}_CLIENT_ID       — required
#   OAUTH_{PROVIDER}_CLIENT_SECRET   — required
#   OAUTH_{PROVIDER}_ISSUER          — for OIDC Discovery (Auth0, Keycloak, Okta, ...)
#   OAUTH_{PROVIDER}_AUTH_URL        — explicit override (rarely needed)
#   OAUTH_{PROVIDER}_TOKEN_URL       — explicit override (rarely needed)
#
# Known providers (via loginpass) only need CLIENT_ID + CLIENT_SECRET.
# URLs are auto-discovered. No config.yaml entry needed.
#
# Redirect URI for all providers:
#   http://localhost:8080/v1/oauth/callback   (development)
#   https://your-domain.com/v1/oauth/callback (production)
# ===========================================================================

# ---------------------------------------------------------------------------
# Google (Gmail, Drive, Calendar, etc.)
# Register at: https://console.cloud.google.com/apis/credentials
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ---------------------------------------------------------------------------
# Microsoft (Outlook, OneDrive, Teams, etc.)
# Register at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_MICROSOFT_CLIENT_ID=your-application-id
# OAUTH_MICROSOFT_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# GitHub
# Register at: https://github.com/settings/applications/new
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_GITHUB_CLIENT_ID=your-client-id
# OAUTH_GITHUB_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# Slack
# Register at: https://api.slack.com/apps
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_SLACK_CLIENT_ID=your-client-id
# OAUTH_SLACK_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# GitLab
# Register at: https://gitlab.com/-/user_settings/applications
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_GITLAB_CLIENT_ID=your-application-id
# OAUTH_GITLAB_CLIENT_SECRET=your-secret

# ---------------------------------------------------------------------------
# Discord
# Register at: https://discord.com/developers/applications
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_DISCORD_CLIENT_ID=your-application-id
# OAUTH_DISCORD_CLIENT_SECRET=your-secret

# ---------------------------------------------------------------------------
# Spotify
# Register at: https://developer.spotify.com/dashboard
# Known provider — only CLIENT_ID + CLIENT_SECRET needed.
# ---------------------------------------------------------------------------
# OAUTH_SPOTIFY_CLIENT_ID=your-client-id
# OAUTH_SPOTIFY_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# Auth0 (OIDC provider — needs ISSUER for auto-discovery)
# Register at: https://manage.auth0.com/dashboard
# ---------------------------------------------------------------------------
# OAUTH_AUTH0_CLIENT_ID=your-client-id
# OAUTH_AUTH0_CLIENT_SECRET=your-client-secret
# OAUTH_AUTH0_ISSUER=https://your-tenant.us.auth0.com

# ---------------------------------------------------------------------------
# Keycloak (OIDC provider — needs ISSUER for auto-discovery)
# ---------------------------------------------------------------------------
# OAUTH_KEYCLOAK_CLIENT_ID=your-client-id
# OAUTH_KEYCLOAK_CLIENT_SECRET=your-client-secret
# OAUTH_KEYCLOAK_ISSUER=https://keycloak.example.com/realms/your-realm

# ---------------------------------------------------------------------------
# Custom / Corporate SSO
# Set AUTH_URL + TOKEN_URL for providers without OIDC Discovery.
# Alternatively, define URLs in config.yaml under oauth_providers.
# ---------------------------------------------------------------------------
# OAUTH_CORP_SSO_CLIENT_ID=your-client-id
# OAUTH_CORP_SSO_CLIENT_SECRET=your-client-secret
# OAUTH_CORP_SSO_AUTH_URL=https://sso.corp.com/oauth2/authorize
# OAUTH_CORP_SSO_TOKEN_URL=https://sso.corp.com/oauth2/token
